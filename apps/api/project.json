{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "root": "apps/api",
  "targets": {
    "build": {
      "dependsOn": ["prisma-generate"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/api"],
      "options": {
        "commands": [
          "npx vite build",
          "npx esbuild src/instrument.ts --bundle --platform=node --format=cjs --outfile=../../dist/apps/api/instrument.cjs --external:@sentry/node --external:dotenv"
        ],
        "cwd": "apps/api",
        "parallel": false
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx --env-file=.env --import ./src/instrument.ts src/server.ts",
        "cwd": "apps/api"
      }
    },
    "prisma-generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma generate",
        "cwd": "apps/api"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run lint",
        "cwd": "apps/api"
      }
    }
  }
}
